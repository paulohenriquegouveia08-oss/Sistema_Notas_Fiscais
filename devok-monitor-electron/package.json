{
  "name": "devok-monitor",
  "version": "1.7.2",
  "description": "Monitor automático de XMLs do Devok para SisFin",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable --x64",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.pkdigital.devokmonitor",
    "productName": "DevokMonitor",
    "artifactName": "DevokMonitor-v${version}.${ext}",
    "win": {
      "target": "portable"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "styles.css"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
